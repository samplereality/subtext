:: StoryTitle
Trialogue Demo

:: StorySubtitle
an interactive chat story

:: Story JavaScript [script]

var leftSidebarContent       = '<h3>Welcome</h3><p>Thanks for trying out <a href="https://github.com/samplereality/trilogue-relog">Trialogue</a>.</p>';
var rightSidebarContent      = '<p>You can place any HTML here.</p><p>Use the <span style="font-family: monospace;">inject_right_sidebar()</span> function in your Story JavaScript.</p>';
var userResponseHintContent  = 'Choose an option to continue the conversation';

inject_left_sidebar(leftSidebarContent);
inject_right_sidebar(rightSidebarContent);
inject_hint(userResponseHintContent);

story.config.sounds = true;


